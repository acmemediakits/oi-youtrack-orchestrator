APP_ENV=development
VERBOSE=false
APP_DATA_DIR=./data
YOUTRACK_BASE_URL=https://example.youtrack.cloud
YOUTRACK_BROWSER_URL=https://example.youtrack.cloud
YOUTRACK_TOKEN=replace-me
YOUTRACK_DEFAULT_ASSIGNEE=developers
YOUTRACK_DEFAULT_ASSIGNEE_LOGIN=acmemediakits
YOUTRACK_ASSIGNEE_FIELD_NAME=Assignee
YOUTRACK_PERSONAL_KB_PROJECT=OPS
YOUTRACK_PERSONAL_KB_FOLDER=Personale
YOUTRACK_DEFAULT_SERVICE_ISSUE=OPS-1
MAILBOX_IMAP_HOST=imap.example.com
MAILBOX_IMAP_PORT=993
MAILBOX_IMAP_TIMEOUT_SECONDS=30
MAILBOX_IMAP_TLS_MODE=ssl
MAILBOX_IMAP_ALLOW_LEGACY_TLS=false
MAILBOX_USERNAME=inbox@example.com
MAILBOX_PASSWORD=replace-me
MAILBOX_FOLDER=INBOX
MAILBOX_PROCESSING_FOLDER=PROCESSING
MAILBOX_PROCESSED_FOLDER=PROCESSED
MAILBOX_FAILED_FOLDER=FAILED
MAILBOX_REJECTED_FOLDER=REJECTED
MAILBOX_SMTP_HOST=smtp.example.com
MAILBOX_SMTP_PORT=587
MAILBOX_SMTP_PROTOCOL=TLS
MAILBOX_SMTP_TIMEOUT_SECONDS=30
MAILBOX_POLL_ENABLED=false
MAILBOX_POLL_INTERVAL_SECONDS=60
MAILBOX_ALLOWED_SENDER_DOMAINS=example.com,client.example
OPENWEBUI_BASE_URL=http://192.168.69.6:8081
OPENWEBUI_CHAT_COMPLETIONS_PATH=/api/chat/completions
OPENWEBUI_API_TOKEN=replace-me
OPENWEBUI_MODEL_ID=YTbot
OPENWEBUI_TIMEOUT_SECONDS=120
OPENWEBUI_TRUSTED_CHANNEL_ENABLED=true
OPENWEBUI_TRUSTED_ACTOR_EMAIL=ytbot@local
OPENWEBUI_TRUSTED_ACTOR_NAME=YTbot
OPENWEBUI_TRUSTED_ACTOR_ROLE=power
